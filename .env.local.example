# Copia questo file in .env.local e sostituisci i placeholder
# con i valori del progetto Supabase (Settings → API / Database).

# Connection string Postgres
# In locale: preferisci Direct connection (db.<ref>.supabase.co:5432) se il pooler :6543 non risponde.
# Su Vercel: Connection pooling / Transaction mode (porta 6543) va bene.
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.xxxx.supabase.co:5432/postgres

# Project URL (Settings → API → Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co

# anon / public key (Settings → API → anon public)
# Deve essere la chiave JWT "anon" (inizia con eyJ...), non la publishable sb_...
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.example

# Opzionale ma consigliato in produzione (redirect OAuth corretti su Vercel/Safari):
# NEXT_PUBLIC_SITE_URL=https://tuo-dominio.vercel.app
